{
    "swagger": "2.0",
    "info": {
        "description": "Frontend API service for OP withdrawals indexer",
        "title": "OP Withdrawals Indexer API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/withdrawal-history": {
            "get": {
                "description": "Returns a list of withdrawals of a chain id initiated by an Ethereum address or proven by it.\nAll withdrawals are fetched which are no older than 90 days.\nOnly non-finalized withdrawals older than that are fetched.\nWithdrawals are fetched in latest-first order.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "withdrawals"
                ],
                "summary": "Get withdrawals history related to an address",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Ethereum address",
                        "name": "address",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Chain id of withdrawal initiation",
                        "name": "chain_id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/withdrawals.EnvelopedWithdrawalHistoryResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorEnvelope"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.ErrorEnvelope"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "response.ErrorEnvelope": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                }
            }
        },
        "withdrawals.EnvelopedWithdrawalHistoryResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                },
                "result": {
                    "type": "object",
                    "properties": {
                        "address": {
                            "type": "string"
                        },
                        "source_chain_id": {
                            "type": "integer"
                        },
                        "withdrawals": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "amount": {
                                        "type": "string"
                                    },
                                    "block_number": {
                                        "type": "integer"
                                    },
                                    "block_timestamp": {
                                        "type": "integer"
                                    },
                                    "chain_id": {
                                        "type": "integer"
                                    },
                                    "decoded_action": {
                                        "type": "string"
                                    },
                                    "from_address": {
                                        "type": "string"
                                    },
                                    "kind": {
                                        "type": "string"
                                    },
                                    "status": {
                                        "type": "string"
                                    },
                                    "to_address": {
                                        "type": "string"
                                    },
                                    "token_address": {
                                        "type": "string"
                                    },
                                    "token_chain_id": {
                                        "type": "integer"
                                    },
                                    "token_class": {
                                        "type": "string"
                                    },
                                    "token_decimals": {
                                        "type": "integer"
                                    },
                                    "token_id": {
                                        "type": "string"
                                    },
                                    "token_name": {
                                        "type": "string"
                                    },
                                    "token_symbol": {
                                        "type": "string"
                                    },
                                    "tx_hash": {
                                        "type": "string"
                                    },
                                    "withdrawal_data": {
                                        "type": "string"
                                    },
                                    "withdrawal_hash": {
                                        "type": "string"
                                    },
                                    "withdrawal_sender": {
                                        "type": "string"
                                    },
                                    "withdrawal_target": {
                                        "type": "string"
                                    },
                                    "withdrawal_value": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}